# ===========================================
# Open API Facturación SRI — Environment Variables Template
# ===========================================
# Copy to .env.development or .env.docker and fill in values

# Server
NODE_ENV=development
PORT=3001
PUBLIC_URL=http://localhost:3001

# Carbone API
CARBONE_API=http://your-carbone-server:3000

# Directories (container paths if Docker)
TEMPLATES_DIR=../templates
PDFS_DIR=../pdfs
CERTS_DIR=../certs
XMLS_DIR=../xmls

# PDF Render
PDF_MAX_ATTEMPTS=2
PDF_RETRY_DELAY=10

# Carbone Options
CARBONE_DEBUG=false
CARBONE_CONVERT_TO=pdf
CARBONE_LANG=en-US

# Signature
SIGNATURE_QR_SIZE=50
SIGNATURE_TOTAL_WIDTH=200
SIGNATURE_DEFAULT_X=0
SIGNATURE_DEFAULT_Y=0
SIGNATURE_DEFAULT_PAGE=-1

# Encryption (REQUIRED — change in production!)
ENCRYPTION_KEY=your-32-byte-encryption-key-here
ENCRYPTION_SALT=your-salt-value-here

# SRI Ecuador
SRI_ENVIRONMENT=development
SRI_RECEPTION_WSDL=https://celcer.sri.gob.ec/comprobantes-electronicos-ws/RecepcionComprobantesOffline?wsdl
SRI_AUTHORIZATION_WSDL=https://celcer.sri.gob.ec/comprobantes-electronicos-ws/AutorizacionComprobantesOffline?wsdl

# Database PostgreSQL (REQUIRED)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=db_sri
DB_USER=postgres
DB_PASSWORD=your-password
DB_SSL=false
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=10000
DB_SLOW_QUERY_THRESHOLD_MS=1000

# Redis (BullMQ + Cache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
CACHE_TTL_SECONDS=300

# SRI Rate Limiting
SRI_REQUEST_DELAY_MS=150
SRI_MAX_RETRIES=3
SRI_RETRY_DELAY_MS=2000
SRI_EMISION_ASYNC=true

# JWT (REQUIRED)
JWT_SECRET=your-jwt-secret-key-32bytes-here
JWT_EXPIRATION=24h

# Vendi Federated Identity (opcional, para validacion de tokens RS256 via JWKS)
# VENDI_JWKS_URL=https://admin.etherlab.dev/.well-known/jwks.json
# VENDI_JWT_ISSUER=https://admin.etherlab.dev
# VENDI_JWT_AUDIENCE=https://api-sri.etherlab.dev

# CORS & Rate Limiting
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Docker Host Volumes (only for docker-compose)
HOST_XMLS_PATH=../xmls

# ===========================================
# Nuevas Variables de Entorno (Mejoras SRI)
# ===========================================

# Tenants
TENANT_DEFAULT_PLAN=BASICO
TENANT_ALLOW_DELETE_WITH_EMISORES=false

# Health Checks
HEALTH_MEMORY_HEAP_MB=150
HEALTH_MEMORY_RSS_MB=300

# SRI Rate Limiting (Recepción y Autorización separados con backoff)
SRI_RECEPCION_RETRIES=3
SRI_RECEPCION_DELAY_MS=1000
SRI_RECEPCION_TIMEOUT_MS=30000
SRI_AUTORIZACION_RETRIES=5
SRI_AUTORIZACION_DELAY_MS=2000
SRI_AUTORIZACION_BACKOFF_MULTIPLIER=1.5
SRI_AUTORIZACION_TIMEOUT_MS=60000

# Colas (attempts, delay, keep completed/failed jobs)
QUEUE_SRI_ATTEMPTS=3
QUEUE_SRI_BACKOFF_MS=2000
QUEUE_SRI_KEEP_COMPLETED=1000
QUEUE_SRI_KEEP_FAILED=5000
QUEUE_WEBHOOK_ATTEMPTS=5
QUEUE_WEBHOOK_BACKOFF_MS=3000
QUEUE_WEBHOOK_KEEP_COMPLETED=500
QUEUE_WEBHOOK_KEEP_FAILED=2000

