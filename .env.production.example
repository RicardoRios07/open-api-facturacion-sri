# ===========================================
# Open API Facturación SRI — .env.production
# ===========================================
# Snapshot NO-sensibles de la configuración que usa el ambiente PRODUCTION
# al 29 Junio 2026. Para valores sensibles, ver Railway dashboard.
#
# REGLA: NUNCA commitear secretos reales. Si necesitas los valores reales,
# ve al dashboard de Railway o usa:
#   railway variables list --json --environment production --service sri-facturacion
#
# Los secretos marcados con <OBTENER_DE_RAILWAY> deben obtenerse de la
# configuración real del servicio en Railway, no commiteados al repo.

# ─── Servidor ───
NODE_ENV=production
PORT=3001
PUBLIC_URL=https://api-sri.etherlab.dev

# ─── Carbone API (PDFs/RIDE) ───
# En production, el servicio Carbone vive dentro del mismo proyecto Railway
# y se accede por la red privada.
CARBONE_API=http://carbone:4000

# ─── Directorios (rutas dentro del contenedor Railway) ───
TEMPLATES_DIR=/data/templates
PDFS_DIR=/data/pdfs
CERTS_DIR=/data/certs
XMLS_DIR=/data/xmls

# ─── PDF Render ───
PDF_MAX_ATTEMPTS=2
PDF_RETRY_DELAY=10

# ─── Opciones Carbone ───
CARBONE_DEBUG=false
CARBONE_CONVERT_TO=pdf
CARBONE_LANG=es-EC

# ─── Seguridad (Cifrado AES-256) ───
# Valores reales en Railway (no commiteables). Para obtener:
#   railway variables get ENCRYPTION_KEY --environment production --service sri-facturacion
ENCRYPTION_KEY=<OBTENER_DE_RAILWAY_PRODUCTION>
ENCRYPTION_SALT=<OBTENER_DE_RAILWAY_PRODUCTION>

# ─── SRI Ecuador ───
# SRI_ENVIRONMENT=development apunta a los WSDL de pruebas (celcer).
# El equipo decidió mantener dev en SRI para desarrollo iterativo.
SRI_ENVIRONMENT=development
SRI_RECEPTION_WSDL=https://celcer.sri.gob.ec/comprobantes-electronicos-ws/RecepcionComprobantesOffline?wsdl
SRI_AUTHORIZATION_WSDL=https://celcer.sri.gob.ec/comprobantes-electronicos-ws/AutorizacionComprobantesOffline?wsdl

# ─── Base de Datos PostgreSQL (Neon — branch main de etherlab) ───
DB_HOST=ep-withered-cherry-aqfieol8.c-8.us-east-1.aws.neon.tech
DB_PORT=5432
DB_NAME=neondb
DB_USER=neondb_owner
DB_PASSWORD=<OBTENER_DE_RAILWAY_PRODUCTION>
DB_SSL=true
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=10000
DB_SLOW_QUERY_THRESHOLD_MS=1000

# ─── Socket Studio API (Consulta RUC y Cédula) ───
SOCKET_STUDIO_TOKEN_RUC=<OBTENER_DE_RAILWAY_PRODUCTION>
SOCKET_STUDIO_TOKEN_CEDULA=<OBTENER_DE_RAILWAY_PRODUCTION>

# ─── Redis (servicio interno del proyecto Railway production) ───
REDIS_HOST=redis.railway.internal
REDIS_PORT=6379
REDIS_PASSWORD=<OBTENER_DE_RAILWAY_PRODUCTION>
REDIS_DB=0
CACHE_TTL_SECONDS=300

# ─── Rate Limiting SRI ───
SRI_REQUEST_DELAY_MS=150
SRI_MAX_RETRIES=3
SRI_RETRY_DELAY_MS=2000
SRI_EMISION_ASYNC=true

# ─── JWT ───
JWT_SECRET=<OBTENER_DE_RAILWAY_PRODUCTION>
JWT_EXPIRATION=24h

# ─── Firma Digital ───
SIGNATURE_QR_SIZE=50
SIGNATURE_TOTAL_WIDTH=200
SIGNATURE_DEFAULT_X=0
SIGNATURE_DEFAULT_Y=0
SIGNATURE_DEFAULT_PAGE=-1

# ─── CORS & Rate Limiting ───
ALLOWED_ORIGINS=https://etherpos.vercel.app,https://ecommerce.etherlab.dev,https://pos.etherlab.dev
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
