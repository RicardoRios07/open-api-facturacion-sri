# ===========================================
# Open API Facturación SRI — .env.staging
# ===========================================
# Snapshot NO-sensibles de la configuración que usa el ambiente STAGING
# al 29 Junio 2026. Para valores sensibles, ver Railway dashboard.
#
# REGLA: NUNCA commitear secretos reales. Si necesitas los valores reales,
# ve al dashboard de Railway o usa:
#   railway variables list --json --environment staging --service open-api-facturacion-sri
#
# Los secretos marcados con <OBTENER_DE_RAILWAY> deben obtenerse de la
# configuración real del servicio en Railway, no commiteados al repo.

# ─── Servidor ───
NODE_ENV=production
PORT=3001
PUBLIC_URL=https://open-api-facturacion-sri-staging.up.railway.app

# ─── Carbone API (PDFs/RIDE) ───
# En staging no tenemos un servicio Carbone dedicado (solo en production).
# Apuntamos al Carbone público de production para que staging pueda renderizar PDFs.
CARBONE_API=https://carbone.etherlab.dev

# ─── Directorios (rutas dentro del contenedor Railway) ───
TEMPLATES_DIR=/data/templates
PDFS_DIR=/data/pdfs
CERTS_DIR=/data/certs
XMLS_DIR=/data/xmls

# ─── PDF Render ───
PDF_MAX_ATTEMPTS=2
PDF_RETRY_DELAY=10

# ─── Opciones Carbone ───
CARBONE_DEBUG=false
CARBONE_CONVERT_TO=pdf
CARBONE_LANG=es-EC

# ─── Seguridad (Cifrado AES-256) ───
# Mismos valores dev que production (staging es dev, no requiere rotación).
# Para obtener:
#   railway variables get ENCRYPTION_KEY --environment staging --service open-api-facturacion-sri
ENCRYPTION_KEY=<OBTENER_DE_RAILWAY_STAGING>
ENCRYPTION_SALT=<OBTENER_DE_RAILWAY_STAGING>

# ─── SRI Ecuador ───
# Staging también apunta a los WSDL de pruebas (celcer) del SRI.
SRI_ENVIRONMENT=development
SRI_RECEPTION_WSDL=https://celcer.sri.gob.ec/comprobantes-electronicos-ws/RecepcionComprobantesOffline?wsdl
SRI_AUTHORIZATION_WSDL=https:...n
# ─── Base de Datos PostgreSQL (Neon — branch staging de etherlab) ───
# Endpoint directo (no el pooler) porque el pooler no responde a la
# password actual de la branch staging. Ver nota en infra-architecture.md.
DB_HOST=ep-still-glade-amdiuyav.c-5.us-east-1.aws.neon.tech
DB_PORT=5432
DB_NAME=neondb
DB_USER=neondb_owner
DB_PASSWORD=<OBTEN...n
# ─── Socket Studio API (Consulta RUC y Cédula) ───
# Mismos tokens dev que production (staging es dev).
SOCKET_STUDIO_TOKEN_RUC=<OBTEN...n
# ─── Redis (servicio Redis-JByd dedicado del environment staging) ───
REDIS_HOST=redis-jbyd.railway.internal
REDIS_PORT=6379
REDIS_PASSWORD=<OBTEN...n
# ─── Rate Limiting SRI ───
SRI_REQUEST_DELAY_MS=150
SRI_MAX_RETRIES=3
SRI_RETRY_DELAY_MS=2000
SRI_EMISION_ASYNC=true

# ─── JWT ───
JWT_SECRET=<OBTEN...n
# ─── Firma Digital ───
SIGNATURE_QR_SIZE=50
SIGNATURE_TOTAL_WIDTH=200
SIGNATURE_DEFAULT_X=0
SIGNATURE_DEFAULT_Y=0
SIGNATURE_DEFAULT_PAGE=-1

# ─── CORS & Rate Limiting ───
# Staging permite todos los origines (*). En production se restringe a
# etherpos.vercel.app, ecommerce.etherlab.dev, pos.etherlab.dev.
ALLOWED_ORIGINS=*
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
